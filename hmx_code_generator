def load_google_sheet(url, sheet_name="data"):
    """Load data from Google Sheets"""
    try:
        sheet_id = url.split('/d/')[1].split('/')[0]
        csv_url = f"https://docs.google.com/spreadsheets/d/{sheet_id}/export?format=csv"
        df = pd.read_csv(csv_url)

        # Clean revenue columns if present
        for col in df.columns:
            if 'Revenue' in col or 'revenue' in col:
                if df[col].dtype == 'object':
                    df[col] = df[col].astype(str).str.replace('$', '').str.replace(',', '').str.replace('-', '0')
                    df[col] = pd.to_numeric(df[col], errors='coerce').fillna(0)

        # Fill NaN values
        df = df.fillna(0)

        print(f"✓ Loaded {len(df)} rows from {sheet_name}")
        print(f"✓ Columns: {', '.join(df.columns)}")
        return df
    except Exception as e:
        print(f"✗ Error loading {sheet_name}: {e}")
        return None

def get_historical_average(df, weeks_out, metric, current_fiscal_year, current_month):
    """Calculate historical average excluding current offering"""
    historical = df[
        (df['Weeks_Out'] == weeks_out) &
        ~((df['Fiscal_Year'] == current_fiscal_year) & (df['Month'] == current_month))
    ]
    return historical[metric].mean() if len(historical) > 0 else 0

def get_color(percentage):
    """Determine color based on percentage"""
    if percentage >= GREEN_THRESHOLD:
        return 'Green', '#99ff99'
    elif percentage >= YELLOW_THRESHOLD:
        return 'Yellow', '#ffff99'
    elif percentage >= ORANGE_THRESHOLD:
        return 'Orange', '#ffcc99'
    else:
        return 'Red', '#ff9999'

def generate_comparison_table(df, weeks_out, current_fiscal_year, current_month):
    """Generate comparison table"""
    metrics = ['Enrollments', 'Revenue']
    current_data = df[
        (df['Fiscal_Year'] == current_fiscal_year) &
        (df['Month'] == current_month) &
        (df['Weeks_Out'] == weeks_out)
    ]

    print(f"\n{'='*70}")
    print(f"COMPARISON - {current_month} {current_fiscal_year} at {weeks_out} Weeks Out")
    print(f"{'='*70}")

    rows = []
    for metric in metrics:
        current_val = current_data[metric].values[0] if len(current_data) > 0 else 0
        hist_avg = get_historical_average(df, weeks_out, metric, current_fiscal_year, current_month)
        percentage = (current_val / hist_avg * 100) if hist_avg > 0 else 0
        color_name, color_hex = get_color(percentage)

        rows.append({
            'metric': metric,
            'current': float(current_val),
            'avg': round(hist_avg, 2),
            'pct': round(percentage, 1),
            'color': color_name,
            'color_hex': color_hex
        })

        if metric == 'Revenue':
            print(f"{metric:12} | Current: $${current_val:,.2f} | Avg: $${hist_avg:,.2f} | {percentage:5.1f}% | {color_name}")
        else:
            print(f"{metric:12} | Current: {int(current_val):6} | Avg: {hist_avg:7.2f} | {percentage:5.1f}% | {color_name}")

    print(f"{'='*70}\n")
    return rows

def create_traces_by_offering(df, current_fiscal_year, current_month, metric, color):
    """Create Plotly traces for a metric, one line per offering"""
    traces = []

    offerings = df.groupby(['Fiscal_Year', 'Month']).size().reset_index()[['Fiscal_Year', 'Month']]
    offerings = offerings.sort_values(['Fiscal_Year', 'Month'])

    positions = ['top right', 'bottom right', 'middle right', 'top center']

    historical = offerings[
        ~((offerings['Fiscal_Year'] == current_fiscal_year) & (offerings['Month'] == current_month))
    ]

    for idx, (_, offering) in enumerate(historical.iterrows()):
        fy = offering['Fiscal_Year']
        month = offering['Month']
        offering_data = df[
            (df['Fiscal_Year'] == fy) & (df['Month'] == month)
        ].sort_values('Weeks_Out', ascending=False)

        if len(offering_data) > 0:
            text_list = [''] * (len(offering_data) - 1) + [f'{month} {fy}']

            traces.append({
                'x': offering_data['Weeks_Out'].tolist(),
                'y': offering_data[metric].tolist(),
                'mode': 'lines+markers+text',
                'name': f'{month} {fy}',
                'line': {'color': color, 'width': 2},
                'marker': {'size': 6, 'symbol': 'circle'},
                'text': text_list,
                'textposition': positions[idx % len(positions)],
                'textfont': {'color': color, 'size': 10},
                'hovertemplate': f'<b>{month} {fy}</b><br>Weeks Out: %{{x}}<br>{metric}: %{{y:,.0f}}<extra></extra>'
            })

    current_data = df[
        (df['Fiscal_Year'] == current_fiscal_year) & (df['Month'] == current_month)
    ].sort_values('Weeks_Out', ascending=False)

    if len(current_data) > 0:
        text_list = [''] * (len(current_data) - 1) + [f'{current_month} {current_fiscal_year}']
        traces.append({
            'x': current_data['Weeks_Out'].tolist(),
            'y': current_data[metric].tolist(),
            'mode': 'lines+markers+text',
            'name': f'{current_month} {current_fiscal_year}',
            'line': {'color': color, 'width': 4},
            'marker': {'size': 10, 'symbol': 'star'},
            'text': text_list,
            'textposition': 'bottom center',
            'textfont': {'color': color, 'size': 12},
            'hovertemplate': f'<b>{current_month} {current_fiscal_year}</b><br>Weeks Out: %{{x}}<br>{metric}: %{{y:,.0f}}<extra></extra>'
        })

    return traces

def create_fiscal_year_traces(df_fiscal):
    """Create traces for fiscal year revenue comparison"""

    month_order = ['July', 'August', 'September', 'October', 'November', 'December',
                   'January', 'February', 'March', 'April', 'May', 'June']

    fiscal_years = sorted(df_fiscal['Fiscal_Year'].unique())

    colors_fy = ['#0074D9', '#2ECC40', '#FF851B', '#B10DC9', '#FFDC00', '#FF4136']

    traces_cumulative = []

    for idx, fy in enumerate(fiscal_years):
        fy_data = df_fiscal[df_fiscal['Fiscal_Year'] == fy].copy()

        fy_data['month_order'] = fy_data['Month'].apply(
            lambda x: month_order.index(x) if x in month_order else 999
        )
        fy_data = fy_data.sort_values('month_order')

        color = colors_fy[idx % len(colors_fy)]

        traces_cumulative.append({
            'x': fy_data['Month'].tolist(),
            'y': fy_data['Fiscal_Year_to_Date'].tolist(),
            'mode': 'lines+markers',
            'name': str(fy),
            'line': {'color': color, 'width': 3},
            'marker': {'size': 8},
            'hovertemplate': f'<b>{fy}</b><br>Through %{{x}}<br>YTD: $%{{y:,.0f}}<extra></extra>'
        })

    return traces_cumulative, month_order

