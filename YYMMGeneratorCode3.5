def load_google_sheet(url):
    """Load data from Google Sheets"""
    try:
        sheet_id = url.split('/d/')[1].split('/')[0]
        csv_url = f"https://docs.google.com/spreadsheets/d/{sheet_id}/export?format=csv"
        df = pd.read_csv(csv_url)
        
        # Create Month_Year column for grouping
        df['Month_Year'] = df['Month'].astype(str) + ' ' + df['Year'].astype(str)
        
        print(f"✓ Loaded {len(df)} rows from Google Sheets")
        print(f"✓ Periods found: {sorted(df['Month_Year'].unique())}")
        print(f"✓ Columns: {', '.join(df.columns)}")
        return df
    except Exception as e:
        print(f"✗ Error loading Google Sheet: {e}")
        print("\nMake sure:")
        print("  1. The sheet is shared as 'Anyone with the link'")
        print("  2. The link is correct")
        print("  3. Column names match exactly: Month, Year, Weeks_Out, Interests, Abandons, Submits, Admits, Expect")
        return None

def get_historical_average(df, weeks_out, stage, current_period):
    """Calculate historical average excluding current period"""
    historical = df[(df['Weeks_Out'] == weeks_out) & (df['Month_Year'] != current_period)]
    return historical[stage].mean() if len(historical) > 0 else 0

def get_color(percentage):
    """Determine color based on percentage"""
    if percentage >= GREEN_THRESHOLD:
        return 'Green', '#99ff99'
    elif percentage >= YELLOW_THRESHOLD:
        return 'Yellow', '#ffff99'
    elif percentage >= ORANGE_THRESHOLD:
        return 'Orange', '#ffcc99'
    else:
        return 'Red', '#ff9999'

def generate_comparison_table(df, weeks_out, current_period, show_stages):
    """Generate comparison table with show/hide capability"""
    stages = ['Interests', 'Abandons', 'Submits', 'Admits', 'Expect']
    current_data = df[(df['Month_Year'] == current_period) & (df['Weeks_Out'] == weeks_out)]

    print(f"\n{'='*60}")
    print(f"COMPARISON TABLE - {current_period} at {weeks_out} Weeks Out")
    print(f"{'='*60}")

    rows = []
    for stage in stages:
        # Skip if stage is hidden
        if not show_stages.get(stage, True):
            print(f"{stage:12} | HIDDEN (not shown in report or charts)")
            continue

        current_val = current_data[stage].values[0] if len(current_data) > 0 else 0
        hist_avg = get_historical_average(df, weeks_out, stage, current_period)
        percentage = (current_val / hist_avg * 100) if hist_avg > 0 else 0
        color_name, color_hex = get_color(percentage)

        rows.append({
            'stage': stage,
            'current': int(current_val),
            'avg': round(hist_avg, 2),
            'pct': round(percentage, 1),
            'color': color_name,
            'color_hex': color_hex
        })

        print(f"{stage:12} | {current_period}: {int(current_val):6} | Avg: {hist_avg:7.2f} | {percentage:5.1f}% | {color_name}")

    print(f"{'='*60}\n")
    return rows

def create_traces(df, current_period, stage, color):
    """Create Plotly traces for a stage"""
    periods = sorted(df['Month_Year'].unique())
    traces = []
    positions = ['top right', 'bottom right', 'middle right', 'top center']

    # Historical periods
    for idx, period in enumerate([p for p in periods if p != current_period]):
        period_data = df[df['Month_Year'] == period].sort_values('Weeks_Out', ascending=False)
        text_list = [''] * (len(period_data) - 1) + [f'{period} {stage}']

        traces.append({
            'x': period_data['Weeks_Out'].tolist(),
            'y': period_data[stage].tolist(),
            'mode': 'lines+markers+text',
            'name': f'{stage} {period}',
            'line': {'color': color, 'width': 2},
            'marker': {'size': 8, 'symbol': 'circle'},
            'text': text_list,
            'textposition': positions[idx % len(positions)],
            'textfont': {'color': color, 'size': 12},
            'hovertemplate': '<b>%{text}</b><br>Weeks Out: %{x}<br>Value: %{y}<extra></extra>'
        })

    # Current period
    current_data = df[df['Month_Year'] == current_period].sort_values('Weeks_Out', ascending=False)
    if len(current_data) > 0:
        text_list = [''] * (len(current_data) - 1) + [f'{current_period} {stage}']
        traces.append({
            'x': current_data['Weeks_Out'].tolist(),
            'y': current_data[stage].tolist(),
            'mode': 'lines+markers+text',
            'name': f'{stage} {current_period}',
            'line': {'color': color, 'width': 4},
            'marker': {'size': 12, 'symbol': 'star'},
            'text': text_list,
            'textposition': 'bottom center',
            'textfont': {'color': color, 'size': 12},
            'hovertemplate': '<b>%{text}</b><br>Weeks Out: %{x}<br>Value: %{y}<extra></extra>'
        })

    return traces

