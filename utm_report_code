# ── 8b. Chart builder ─────────────────────────────────────────
def bar_fig(cats, vals, color):
    max_val = max(vals) if vals else 1
    y_max   = max_val * 1.20
    fig = go.Figure(go.Bar(
        x=cats, y=vals,
        text=[f"{v:.2f}" for v in vals],
        textposition="outside",
        textfont=dict(size=10.5, color="#555"),
        marker_color=color,
        marker_line_color="rgba(0,0,0,.05)",
        marker_line_width=1,
        hovertemplate="<b>%{x}</b><br>Credit: %{y:.2f}<extra></extra>",
    ))
    fig.update_layout(
        autosize=True, height=340,
        margin=dict(t=20, b=10, l=46, r=18),
        plot_bgcolor="white",
        paper_bgcolor="rgba(0,0,0,0)",
        font=dict(family="Inter, Segoe UI, Arial, sans-serif", color="#555"),
        xaxis=dict(tickangle=-40, showgrid=False, showline=True,
                   linecolor="#e4e4e4"),
        yaxis=dict(
            showgrid=True, gridcolor="#f0f0f0", zeroline=False,
            title_text="Attribution Credit", title_font_size=12,
            range=[0, y_max],
        ),
        showlegend=False, bargap=0.3,
    )
    return fig

_cfg = {"responsive": True, "displayModeBar": False}

# ── 8c. Render charts from filtered data ──────────────────────
src_chart = pio.to_html(
