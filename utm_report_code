_src_cols = [c for c in [
    "Contact Original Source",
    "Course Connection First Source",
    "Course Connection Latest Source",
] if c in df_raw.columns]

_med_cols = [c for c in [
    "Contact Original Medium",
    "Course Connection First Medium",
    "Course Connection Latest Medium",
] if c in df_raw.columns]

