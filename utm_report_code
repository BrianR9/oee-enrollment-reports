_norm(_attr_cols, r"twitter|x\.com",      "twitter",   "Twitter / X variants")
_norm(_attr_cols, r"tiktok",              "tiktok",    "TikTok variants")
_norm(_attr_cols, r"snapchat",            "snapchat",  "Snapchat variants")
_norm(_attr_cols, r"pinterest",           "pinterest", "Pinterest variants")
_norm(_attr_cols, r"\bbing\b",            "bing",      "Bing variants")
_norm(_attr_cols, r"\be[\-_]?mail\b",     "email",     "Email variants")

# ── 3m. Medium normalisation (medium cols only) ───────────────
