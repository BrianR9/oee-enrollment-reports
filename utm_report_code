        df_raw.loc[mask, col] = (
            df_raw.loc[mask, col]
            .str.replace(r"[()]", "", regex=True)
            .str.strip()
        )
        paren_report[col] = n
if paren_report:
    print("✅  Parentheses stripped (e.g. '(direct)' → 'direct'):")
