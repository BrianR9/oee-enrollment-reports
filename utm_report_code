# ── 3h. Helper: contains-based normalisation ─────────────────
def _norm(cols, pattern, replacement, label, regex=True):
    report = {}
    for col in cols:
        if col not in df_raw.columns:
            continue
        mask = (
            df_raw[col].str.contains(pattern, na=False, regex=regex)
            & (df_raw[col] != replacement)
        )
        n = int(mask.sum())
        if n:
            df_raw.loc[mask, col] = replacement
            report[col] = n
    if report:
        print(f"✅  {label} → '{replacement}':")
        for col, n in report.items():
            print(f"      {col}: {n:,} cell(s)")
    else:
        print(f"✅  No {label.lower()} found.")

