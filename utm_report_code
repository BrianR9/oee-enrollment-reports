# ── 3s. Harvard website / HMS normalisation ───────────────────
print("── Harvard / HMS normalisation ───────────────────────────")
harvard_report = {}
for col in _attr_cols:
    if col not in df_raw.columns:
        continue
    mask_harvard = (
        df_raw[col].str.contains("harvard", na=False, regex=False)
        & ~df_raw[col].str.contains("pll.harvard.edu", na=False, regex=False)
    )
    mask_hms = df_raw[col].str.contains(r"\bhms\b", na=False, regex=True)
    mask = (mask_harvard | mask_hms) & (df_raw[col] != "harvard website")
    n = int(mask.sum())
    if n:
        df_raw.loc[mask, col] = "harvard website"
        harvard_report[col]   = n
if harvard_report:
    print("✅  Harvard URLs / HMS references → 'harvard website':")
    for col, n in harvard_report.items():
        print(f"      {col}: {n:,} cell(s)")
else:
    print("✅  No Harvard URL / HMS references found.")

print("\n✅  All clean-up steps complete.")

# ── 4. Column pairs & enrolled filter ────────────────────────
SOURCE_MEDIUM_PAIRS = [
    ("Contact Original Source",         "Contact Original Medium"),
    ("Course Connection First Source",  "Course Connection First Medium"),
    ("Course Connection Latest Source", "Course Connection Latest Medium"),
]
df_enrolled = df_raw[df_raw["Enrollment Status"] == "enrolled"].copy()

# ── 5. Helpers ────────────────────────────────────────────────
BLANKS    = {"", "blank", "nan", "none", "n/a", "na"}
MEDIUMMAP = {
    "sponsored":   "paid-social",
    "ppc":         "cpc",
    "paid search": "cpc",
    "paid-search": "cpc",
    "paid_search": "cpc",
    "e-mail":      "email",
    "e_mail":      "email",
}

def is_valid(v)  -> bool: return str(v).strip().lower() not in BLANKS
def norm_med(v)  -> str:  s = str(v).strip().lower(); return MEDIUMMAP.get(s, s)
def n_valid(row) -> int:
    return sum(
        int(is_valid(row[sc])) + int(is_valid(row[mc]))
        for sc, mc in SOURCE_MEDIUM_PAIRS
    )

# ── 6. Classify rows ──────────────────────────────────────────
df_enrolled["n_valid"] = df_enrolled.apply(n_valid, axis=1)
total_all_blank        = int((df_enrolled["n_valid"] == 0).sum())
df                     = df_enrolled[df_enrolled["n_valid"] > 0].copy()
total_with_data        = len(df)

# ── 7. Attribution credits ────────────────────────────────────
src_ctr: Counter = Counter()
med_ctr: Counter = Counter()

for _, row in df.iterrows():
    srcs = [str(row[sc]).strip().lower() for sc, _  in SOURCE_MEDIUM_PAIRS if is_valid(row[sc])]
    meds = [norm_med(row[mc])            for _,  mc in SOURCE_MEDIUM_PAIRS if is_valid(row[mc])]
    if srcs:
        c = 1 / len(srcs)
        for s in srcs: src_ctr[s] += c
    if meds:
        c = 1 / len(meds)
        for m in meds: med_ctr[m] += c

src_df = (pd.DataFrame(src_ctr.items(), columns=["Source", "Credit"])
            .sort_values("Credit", ascending=False).reset_index(drop=True))
med_df = (pd.DataFrame(med_ctr.items(), columns=["Medium", "Credit"])
            .sort_values("Credit", ascending=False).reset_index(drop=True))
total_sources = len(src_df)
total_mediums = len(med_df)

