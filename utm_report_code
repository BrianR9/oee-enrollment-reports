# ── 3b. Normalise all text columns to lowercase ──────────────
string_cols = df_raw.select_dtypes(include=["object", "string"]).columns
df_raw[string_cols] = (
    df_raw[string_cols]
    .apply(lambda col: col.str.strip().str.lower())
)
print(f"✅  Lowercased & stripped {len(string_cols)} text column(s): "
      f"{string_cols.tolist()}")

# ── 3b-ii. Collapse internal whitespace ──────────────────────
df_raw[string_cols] = df_raw[string_cols].apply(
    lambda col: col.str.replace(r"\s+", " ", regex=True).str.strip()
)
print("✅  Internal whitespace collapsed.")

# ── 3c. Fill empty / NaN cells with "blank" ──────────────────
df_raw[string_cols] = (
    df_raw[string_cols]
    .fillna("blank")
    .replace("", "blank")
)
blank_counts = (df_raw[string_cols] == "blank").sum()
blank_cols   = blank_counts[blank_counts > 0]
if len(blank_cols):
    print("✅  Empty / NaN cells replaced with 'blank':")
    for col, n in blank_cols.items():
        print(f"      {col}: {n:,} cell(s)")
else:
    print("✅  No empty / NaN cells found in text columns.")

# ── 3d. Contains "webinar" → "webinar" ───────────────────────
webinar_report = {}
for col in string_cols:
    mask = df_raw[col].str.contains("webinar", na=False)
