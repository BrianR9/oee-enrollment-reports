    default_width="100%", default_height="340px")

# ── 9. Data tables ────────────────────────────────────────────
def build_table(df, col, accent):
    total = df["Credit"].sum()
    rows  = "".join(
        f'<tr>'
        f'<td><span class="badge {accent}">{i + 1}</span></td>'
        f'<td><span class="iname">{row[col]}</span></td>'
        f'<td class="num">{row["Credit"]:.2f}</td>'
        f'<td><div class="bwrap">'
        f'<div class="bfill {accent}" style="width:{min(row["Credit"]/total*100,100):.1f}%"></div>'
        f'<span class="blabel">{row["Credit"]/total*100:.1f}%</span>'
        f'</div></td>'
        f'</tr>'
        for i, row in df.iterrows()
    )
    return (
        f'<div class="twrap"><table class="dtable">'
        f'<thead><tr>'
        f'<th style="width:38px">#</th>'
        f'<th>{col}</th>'
        f'<th class="num" style="width:80px">Credit</th>'
        f'<th style="min-width:150px">Share of Total</th>'
        f'</tr></thead>'
        f'<tbody>{rows}</tbody>'
        f'</table></div>'
    )

