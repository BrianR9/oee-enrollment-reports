    "not set", "not provided", "not available",
    "unknown", "undefined", "none", "null", "nan",
}
ns_report = {}
for col in string_cols:
    mask = df_raw[col].isin(_NOT_SET)
    n    = int(mask.sum())
    if n:
        df_raw.loc[mask, col] = "blank"
        ns_report[col] = n
