                "shapes": [{{"line": {{"color": "gray", "dash": "dash", "width": 2}}, "type": "line", "x0": {weeks_out}, "x1": {weeks_out}, "xref": "x", "y0": 0, "y1": 1, "yref": "y domain"}}],
